{
  "name": "desta-market",
  "version": "1.0.0",
  "description": "DESTA B2B MARKET - Ethiopian B2B Marketplace Platform",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "cd backend && npm run start:dev",
    "dev:frontend": "cd apps/web && npm run dev",
    "build": "npm run build:backend && npm run build:frontend",
    "build:backend": "cd backend && npm run build",
    "build:frontend": "cd apps/web && npm run build",
    "prisma:generate": "cd backend && npx prisma generate",
    "prisma:migrate": "cd backend && npx prisma migrate dev",
    "docker:up": "cd docker && docker-compose up -d",
    "docker:down": "cd docker && docker-compose down"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
